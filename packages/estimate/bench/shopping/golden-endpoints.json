{
  "project": "shopping",
  "endpoints": [
    { "method": "POST", "path": "/auth/customers/join", "description": "Customer sign up" },
    { "method": "POST", "path": "/auth/customers/login", "description": "Customer login" },
    { "method": "POST", "path": "/auth/sellers/join", "description": "Seller sign up" },
    { "method": "POST", "path": "/auth/sellers/login", "description": "Seller login" },
    { "method": "GET", "path": "/customers/profile", "description": "Get customer profile" },
    { "method": "PATCH", "path": "/customers/profile", "description": "Update customer profile" },
    { "method": "GET", "path": "/customers/addresses", "description": "List addresses" },
    { "method": "POST", "path": "/customers/addresses", "description": "Add address" },
    { "method": "PATCH", "path": "/customers/addresses/:id", "description": "Edit address" },
    { "method": "DELETE", "path": "/customers/addresses/:id", "description": "Delete address" },
    { "method": "GET", "path": "/categories", "description": "List categories" },
    { "method": "GET", "path": "/products", "description": "Search/list products" },
    { "method": "GET", "path": "/products/:id", "description": "Get product detail" },
    { "method": "POST", "path": "/sellers/products", "description": "Create product" },
    { "method": "PATCH", "path": "/sellers/products/:id", "description": "Edit product" },
    { "method": "DELETE", "path": "/sellers/products/:id", "description": "Delete product" },
    { "method": "POST", "path": "/sellers/products/:id/variants", "description": "Add variant" },
    { "method": "PATCH", "path": "/sellers/products/:id/variants/:variantId", "description": "Edit variant" },
    { "method": "POST", "path": "/sellers/products/:id/variants/:variantId/inventory", "description": "Adjust inventory" },
    { "method": "GET", "path": "/customers/wishlist", "description": "Get wishlist" },
    { "method": "POST", "path": "/customers/wishlist", "description": "Add to wishlist" },
    { "method": "DELETE", "path": "/customers/wishlist/:id", "description": "Remove from wishlist" },
    { "method": "GET", "path": "/customers/cart", "description": "Get cart" },
    { "method": "POST", "path": "/customers/cart", "description": "Add to cart" },
    { "method": "PATCH", "path": "/customers/cart/:id", "description": "Update cart item" },
    { "method": "DELETE", "path": "/customers/cart/:id", "description": "Remove from cart" },
    { "method": "POST", "path": "/customers/orders", "description": "Place order" },
    { "method": "GET", "path": "/customers/orders", "description": "Order history" },
    { "method": "GET", "path": "/customers/orders/:id", "description": "Order detail" },
    { "method": "POST", "path": "/customers/orders/:id/items/:itemId/cancel", "description": "Request cancellation" },
    { "method": "POST", "path": "/customers/orders/:id/items/:itemId/refund", "description": "Request refund" },
    { "method": "POST", "path": "/sellers/shipments", "description": "Create shipment" },
    { "method": "PATCH", "path": "/customers/shipments/:id/deliver", "description": "Confirm delivery" },
    { "method": "POST", "path": "/customers/reviews", "description": "Write review" },
    { "method": "PATCH", "path": "/customers/reviews/:id", "description": "Edit review" },
    { "method": "DELETE", "path": "/customers/reviews/:id", "description": "Delete review" },
    { "method": "GET", "path": "/admin/sellers/pending", "description": "List pending sellers" },
    { "method": "PATCH", "path": "/admin/sellers/:id/approve", "description": "Approve/reject seller" },
    { "method": "POST", "path": "/admin/categories", "description": "Create category" },
    { "method": "PATCH", "path": "/admin/categories/:id", "description": "Edit category" },
    { "method": "DELETE", "path": "/admin/categories/:id", "description": "Delete category" }
  ]
}
