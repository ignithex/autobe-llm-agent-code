{
  "private": true,
  "name": "@autobe/test",
  "version": "0.30.0-dev.20260315",
  "description": "AutoBE Test Program",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "build:prompt": "node build/prompt.js",
    "dev": "tsc --watch --noEmit",
    "start": "ts-node src/index.ts",
    "archive:benchmark": "pnpm run build:prompt && node -r ts-node/register --max-old-space-size=16000 src/archive/benchmark.ts",
    "archive:go": "pnpm run build:prompt && node -r ts-node/register --max-old-space-size=8000 src/archive/go.ts",
    "archive:failures": "ts-node src/archive/failures.ts > failures.log",
    "archive:commit": "node -r ts-node/register --max-old-space-size=8000 src/archive/commit.ts",
    "archive:debug": "ts-node src/archive/debug.ts",
    "archive:local": "ts-node src/archive/local.ts",
    "archive:publish": "ts-node src/archive/publish.ts",
    "test:instruction": "pnpm run build:prompt && ts-node src/experimental/instruction.ts"
  },
  "author": "Wrtn Technologies",
  "license": "AGPL-3.0",
  "dependencies": {
    "@agentica/core": "catalog:agentica",
    "@autobe/agent": "workspace:^",
    "@autobe/benchmark": "workspace:^",
    "@autobe/compiler": "workspace:^",
    "@autobe/filesystem": "workspace:^",
    "@autobe/interface": "workspace:^",
    "@autobe/playground-api": "workspace:^",
    "@autobe/playground-server": "workspace:^",
    "@autobe/utils": "workspace:^",
    "@nestia/core": "catalog:samchon",
    "@nestia/e2e": "catalog:samchon",
    "@nestia/fetcher": "catalog:samchon",
    "@nestia/migrate": "catalog:samchon",
    "@typia/interface": "catalog:samchon",
    "@typia/utils": "catalog:samchon",
    "dotenv": "^16.5.0",
    "dotenv-expand": "^12.0.2",
    "openai": "catalog:libs",
    "pluralize": "^8.0.0",
    "tgrid": "catalog:samchon",
    "tstl": "catalog:samchon",
    "typia": "catalog:samchon",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/pluralize": "^0.0.33",
    "@types/uuid": "^10.0.0",
    "chalk": "4.1.2",
    "rimraf": "^6.0.1",
    "ts-node": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
